# Comma-separated git author emails to include in the report
GIT_REPORT_EMAILS="user1@example.com,user2@example.com"

# (Optional) Comma-separated paths to git repos or parent directories.
# If not set, ALL repos on your machine are auto-discovered and filtered
# to those with commits from the emails above.
# GIT_REPORT_REPOS="~/projects,~/work/api-server"
